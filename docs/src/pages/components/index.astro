	<h3 id="tabularformfield">TabularFormField</h3>
	<p>
		<code>TabularFormField</code> components return a <code>Tr</code> table row with
		two cells: a <code>Th</code> containing the input's
		<code>Label</code>, and a <code>Td</code> containing the form input.
	</p>
	<pre
		data-role="codeBlock"
		data-info="html"
		class="language-html html"><code><span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>tr</span>
  <span class="token attr-name">id</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>income-wrapper<span class="token punctuation">"</span></span>
  <span class="token attr-name">class</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>tabular-form-field dollars<span class="token punctuation">"</span></span>
<span class="token punctuation">&gt;</span></span>
  <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>th</span> <span class="token attr-name">id</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>_A3UW9FoSLxiwYiCp29Db9A<span class="token punctuation">"</span></span><span class="token punctuation">&gt;</span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>label</span>
      <span class="token attr-name">id</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>income-label<span class="token punctuation">"</span></span>
      <span class="token attr-name">for</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>income<span class="token punctuation">"</span></span>
      <span class="token punctuation">&gt;</span></span>Income<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>label</span>
    <span class="token punctuation">&gt;</span></span>
  <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>th</span><span class="token punctuation">&gt;</span></span>
  <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>td</span> <span class="token attr-name">id</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>_8voTWs6PYLjs58ioz8mwBu<span class="token punctuation">"</span></span><span class="token punctuation">&gt;</span></span>
    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>input</span>
      <span class="token attr-name">id</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>income<span class="token punctuation">"</span></span>
      <span class="token attr-name">name</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>income<span class="token punctuation">"</span></span>
      <span class="token attr-name">type</span><span class="token attr-value"><span class="token punctuation attr-equals">=</span><span class="token punctuation">"</span>Number<span class="token punctuation">"</span></span>
    <span class="token punctuation">/&gt;</span></span>
  <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>td</span><span class="token punctuation">&gt;</span></span>
<span class="token tag"><span class="token tag"><span class="token punctuation">&lt;/</span>tr</span><span class="token punctuation">&gt;</span></span>
</code></pre>
	<ul>
		<li>
			<strong>TabularBooleanField</strong>
			<code>= (field = {}) =&gt; (attributes = {}) =&gt;</code>
		</li>
		<li>
			<strong>TabularCheckboxField</strong>
			<code>= (field = {}) =&gt; (attributes = {}) =&gt;</code>
		</li>
		<li>
			<strong>TabularNumberField</strong>
			<code>= (field = {}) =&gt; (attributes = {}) =&gt;</code>
		</li>
	</ul>
</Layout>
