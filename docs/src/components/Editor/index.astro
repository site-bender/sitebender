---
const { content, height = "20rem" } = Astro.props
---

<section
	data-content={content}
	id="sb-editor"
	style={{ height }}
>
	<script
		src="https://flems.io/flems.html"
		type="text/javascript"
		charset="utf-8"
	></script>
</section>
<script>
	const section = document.querySelector("#sb-editor")
	const content = section.dataset?.content
	const css = `
	body {
		background-color: ghostwhite;
		color: #darkslategray;
		font-family: system-ui, sans-serif;
		font-size: 1.5rem;
		font-weight: 400;
		margin: 1rem;
	}

	code {
		font-size: 1rem;
	}

	pre {
		margin-block-start: 4rem;
	}
	`

	const html = `<!DOCTYPE html>
<html lang="en">
	<head></head>
	<body>
		<output id="output"></output>
		<code><pre id="code-output"></pre></code>
	<body>
</html>
`

	const flems = Flems(section, {
		files: [
			{
				name: "index.js",
				content,
			},
			{
				name: "index.css",
				content: css,
			},
			{
				name: "index.html",
				content: html,
			},
		],
		links: [
			{
				name: "mithril",
				type: "script",
				url: "https://unpkg.com/mithril",
			},
			{
				name: "sitebender",
				type: "script",
				url: "https://unpkg.com/@sitebender/sitebender@0.1.6",
			},
		],
		toolbar: false,
		console: false,
	})
</script>
