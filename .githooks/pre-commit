#!/bin/sh

# Contract validation pre-commit hook
# Ensures no contract violations are committed

echo "🔍 Running contract validation..."

# Run the contract validation script
deno run --allow-read --allow-run scripts/validateContracts.ts

if [ $? -ne 0 ]; then
    echo "❌ Contract violations detected. Commit aborted."
    echo "Fix the violations and try again."
    exit 1
fi

echo "✅ Contract validation passed"

# Run other standard checks
echo "🧪 Running tests..."
deno task test

if [ $? -ne 0 ]; then
    echo "❌ Tests failed. Commit aborted."
    exit 1
fi

echo "🎨 Checking formatting..."
deno task fmt --check

if [ $? -ne 0 ]; then
    echo "❌ Code is not formatted. Run 'deno task fmt' and try again."
    exit 1
fi

# echo "🔍 Running linter..."
