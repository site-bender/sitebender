#!/usr/bin/env bash
set -euo pipefail

# Secret override (Architect only) bypasses all checks when exported
if [[ "${THE_ARCHITECT_APPROVED:-}" == "1" ]]; then
    echo "[hooks] ⚠️ override active (architect approved) — skipping checks"
    exit 0
fi

echo "[hooks] Starting pre-commit pipeline…"

# Ensure Deno exists early
if ! command -v deno >/dev/null 2>&1; then
    echo "[hooks] ❌ deno not found in PATH" >&2
    exit 1
fi

# 1. Contract / boundary enforcement
echo "[hooks] 🔍 Contract validation..."
deno run --allow-read --allow-run scripts/validateContracts/index.ts || {
    echo "[hooks] ❌ Contract violations detected" >&2
    exit 1
}
echo "[hooks] ✅ Contracts clean"

# 2. Protected path enforcement (uses git common dir for worktrees)
GIT_DIR=$(git rev-parse --git-common-dir)
PROTECTED_FILE="${GIT_DIR}/protected-paths.txt"
if [[ -f "$PROTECTED_FILE" ]]; then
    echo "[hooks] 🔐 Checking protected paths..."
    while IFS= read -r changed; do
        while IFS= read -r protected; do
            [[ -z "$protected" ]] && continue
            if grep -q "^$protected" <(echo "$changed"); then
                echo "[hooks] ❌ Protected path change without approval" >&2
                echo "[hooks] Path: $protected" >&2
                echo "[hooks] File: $changed" >&2
                exit 1
            fi
        done < "$PROTECTED_FILE"
    done < <(git diff --cached --name-only)
    echo "[hooks] ✅ Protected paths untouched"
fi

# 3. FP discipline checks (engine)
echo "[hooks] 🧪 FP check (engine)..."
if ! deno task fp:engine >/dev/null 2>&1; then
    echo "[hooks] ❌ FP violations (engine)" >&2
    exit 1
fi
echo "[hooks] ✅ Engine FP clean"

# 4. FP discipline checks (components)
echo "[hooks] 🧪 FP check (components)..."
if ! deno task fp:components >/dev/null 2>&1; then
    echo "[hooks] ❌ FP violations (components)" >&2
    exit 1
fi
echo "[hooks] ✅ Components FP clean"

# 5. Tests
echo "[hooks] 🧪 Running tests..."
deno task test || { echo "[hooks] ❌ Tests failed" >&2; exit 1; }
echo "[hooks] ✅ Tests passing"

# 6. Lint alias import policy
echo "[hooks] 🔎 Alias import policy..."
if ! deno task lint:aliases >/dev/null 2>&1; then
    echo "[hooks] ❌ Alias import policy violation" >&2
    exit 1
fi
echo "[hooks] ✅ Alias imports clean"

# 7. No React junk
echo "[hooks] 🗑  React junk scan..."
if ! deno task lint:no-react-junk >/dev/null 2>&1; then
    echo "[hooks] ❌ React junk detected" >&2
    exit 1
fi
echo "[hooks] ✅ No React junk"

# 8. Coverage ignore audit
echo "[hooks] 📏 Coverage ignore audit..."
IGNORE_CHECK=$(deno run --allow-read scripts/reportIgnored/index.ts 2>&1 || true)
if echo "$IGNORE_CHECK" | grep -F "<no reason provided>" >/dev/null 2>&1; then
    echo "[hooks] ❌ Coverage ignore without reason" >&2
    echo "$IGNORE_CHECK" | grep -A1 "<no reason provided>" >&2
    exit 1
fi
echo "[hooks] ✅ Coverage ignore audit clean"

# 9. Formatting
echo "[hooks] 🎨 Formatting check..."
deno task fmt --check || { echo "[hooks] ❌ Formatting issues" >&2; exit 1; }
echo "[hooks] ✅ Formatting clean"

# 10. Lint
echo "[hooks] 🔍 Linting..."
deno task lint || { echo "[hooks] ❌ Lint errors" >&2; exit 1; }
echo "[hooks] ✅ Lint clean"

# 11. Type checking
echo "[hooks] 📝 Type checking..."
deno task typecheck || { echo "[hooks] ❌ Type errors" >&2; exit 1; }
echo "[hooks] ✅ Types clean"

echo "[hooks] ✅ All pre-commit checks passed"
exit 0
