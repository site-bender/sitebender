{
	"version": "2025-09-08-initial",
	"rules": {
		"oneFunctionPerFile": true,
		"foldersNamedFilesNot": true,
		"typesInTypesFolder": true,
		"constantsInConstantsFolder": true,
		"arrayGenericNotation": true,
		"noMutableArrayMethods": true,
		"requireEnvoyMarker": true
	},
	"forbiddenMutableMethods": ["push", "pop", "shift", "unshift", "splice"],
	"sourceGlobs": [
		"libraries/envoy/src/**/*.ts",
		"!**/types/**",
		"!**/constants/**",
		"!**/*.test.ts"
	],
	"testFilePattern": "**/index.test.ts"
}
